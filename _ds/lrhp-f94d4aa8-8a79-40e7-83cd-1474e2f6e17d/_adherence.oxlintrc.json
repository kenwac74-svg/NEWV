{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "AIHP-update/assets/js/**",
              "assets/js/**",
              "github-upload/assets/js/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cinzel|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Cinzel, Inter, JetBrains Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--accent-base",
      "--bg-page",
      "--blue-system",
      "--border-card",
      "--color-black",
      "--color-cream",
      "--color-ink",
      "--color-muted",
      "--color-panel",
      "--color-void",
      "--font-body",
      "--font-display",
      "--font-mono",
      "--glow-card-inner",
      "--gold-base",
      "--gold-deep",
      "--gold-glow",
      "--gold-highlight",
      "--green-success",
      "--line-gold-mid",
      "--line-gold-soft",
      "--line-white-soft",
      "--radius-lg",
      "--radius-md",
      "--radius-pill",
      "--radius-sm",
      "--radius-xl",
      "--red-alert",
      "--red-bright",
      "--red-deep",
      "--red-mid",
      "--shadow-card",
      "--shadow-glow-gold",
      "--shadow-glow-red",
      "--shadow-panel",
      "--space-1",
      "--space-2",
      "--space-3",
      "--space-4",
      "--space-5",
      "--space-6",
      "--space-7",
      "--space-8",
      "--surface-card",
      "--surface-void",
      "--text-body",
